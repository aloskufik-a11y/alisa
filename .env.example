# Скопируй этот файл в .env и заполни значения

# ── Userbot ──────────────────────────────────────────
# Получи API_ID и API_HASH на https://my.telegram.org → API development tools
API_ID=
API_HASH=

# ── Bot для уведомлений ─────────────────────────────
# Создай через @BotFather в Telegram, скопируй токен сюда
BOT_TOKEN=

# Твой Telegram user ID (узнать у @userinfobot)
USER_ID=

# ── Каналы для прослушивания (опционально) ──────────
# Список каналов/ботов через запятую (без @)
CHANNELS=portals,main_mrkt_bot,MRKT

# ── Интервалы опроса в секундах (опционально) ───────
FRAGMENT_POLL_INTERVAL=60
MRKT_POLL_INTERVAL=90
